# .qwenignore — файлы и директории, которые AI не увидит
# Формат: glob-паттерны, по одному на строку
# Комментарии начинаются с #
#
# Этот файл работает аналогично .gitignore, но для AI-ассистента.
# Все указанные здесь файлы автоматически перекрываются при запуске
# и не будут доступны внутри контейнера.

# === Секреты и окружение ===
.env
.env.*
.env.local
.env.*.local

# === Ключи и сертификаты ===
*.key
*.pem
*.crt
*.pk
*.token
*.password

# === Файлы с учётными данными ===
credentials.json
client_secret*.json
secrets.json
config/secrets.yml

# === Директории с секретами ===
secrets/
secret/
credentials/

# === SSH-ключи ===
id_rsa
id_dsa
id_ed25519
*.pub

# === Базы данных и дампы (могут содержать данные) ===
*.sql
dump/
backups/

# === Тяжёлые директории (экономия токенов) ===
node_modules/
vendor/
.venv/
__pycache__/

# === Лог-файлы ===
*.log
logs/
