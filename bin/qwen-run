#!/bin/bash
# bin/qwen-run — упрощённый прямой запуск Qwen Code (без compose)
set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# ----- Конфигурация -----
_RESOLVED="$(readlink -f "$0" 2>/dev/null || echo "$0")"
SCRIPT_DIR="$(cd "$(dirname "$_RESOLVED")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
VERSION=$(cat "$PROJECT_ROOT/VERSION" 2>/dev/null || echo "unknown")
QWEN_IMAGE="${QWEN_IMAGE:-$(cat "$PROJECT_ROOT/IMAGE")}"
CONFIG_NAME="${QWEN_CONFIG_NAME:-qwen-code-container}"
GLOBAL_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/$CONFIG_NAME"
PROJECT_DIR="$(pwd)"
PROJECT_HASH=$(echo -n "$PROJECT_DIR" | md5sum | cut -d' ' -f1)
CONTAINER_NAME="qcc-$(echo "$PROJECT_HASH" | head -c 8)"
PROJECT_CONFIG_DIR="$GLOBAL_CONFIG_DIR/projects/$PROJECT_HASH"
PROJECT_QWEN_DIR="$PROJECT_CONFIG_DIR/.qwen"
HOST_PORT="${HOST_PORT:-5173}"
CONTAINER_PORT="${CONTAINER_PORT:-5173}"
QWEN_MODEL="${QWEN_MODEL:-qwen-coder}"
QWEN_MODEL_EXPLICIT="${QWEN_MODEL_EXPLICIT:-0}"

# ----- Поиск свободного порта на хосте -----
# Если порт 5173 занят другим контейнером qcc — ищем следующий свободный
find_free_port() {
    local port=$1
    local max_attempts=20
    local i=0
    while [ $i -lt $max_attempts ]; do
        if ! $CONTAINER_CMD ps --format '{{.Ports}}' 2>/dev/null | grep -q ":${port}->"; then
            echo "$port"
            return
        fi
        port=$((port + 1))
        i=$((i + 1))
    done
    echo "$1"  # fallback — возвращаем оригинальный
}

# ----- Обработка аргументов -----
DEBUG_MODE=0
if [ "${1:-}" = "--debug" ]; then
    DEBUG_MODE=1
    shift
fi
if [ "${1:-}" = "--version" ] || [ "${1:-}" = "-v" ]; then
    echo "qcc v$VERSION (образ: $QWEN_IMAGE)"
    exit 0
fi
if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    echo "Qwen Code Launcher v$VERSION"
    echo ""
    echo "Использование: qcc [опции]"
    echo ""
    echo "Опции:"
    echo "  --help, -h       Показать справку"
    echo "  --version, -v    Показать версию"
    echo "  --model          Показать текущую модель"
    echo "  --stop           Остановить запущенный контейнер qcc"
    echo "  --attach         Подключиться к запущенной сессии"
    echo "  --new            Запустить новый контейнер"
    echo "  --debug          Показать команду запуска без выполнения"
    echo ""
    echo "Повторный запуск:"
    echo "  Если контейнер уже запущен из этого же проекта — спросит,"
    echo "  подключиться к сессии или запустить новый."
    echo "  Если из другого проекта — остановит старый и запустит новый."
    echo ""
    echo "Переменные окружения:"
    echo "  QWEN_IMAGE     Docker-образ (по умолчанию: $QWEN_IMAGE)"
    echo "  QWEN_MODEL     Модель для AI (по умолчанию: из ~/.config/.../model)"
    echo "  HOST_PORT      Порт на хосте (по умолчанию: 5173)"
    echo ""
    echo "Документация: https://github.com/qwenlm/qwen-code"
    exit 0
fi
if [ "${1:-}" = "--model" ]; then
    # Показать модель и выйти
    if [ -f "$GLOBAL_CONFIG_DIR/model" ]; then
        echo "🤖 Текущая модель: $(cat "$GLOBAL_CONFIG_DIR/model")"
    else
        echo "🤖 Модель не задана (используется по умолчанию от провайдера)"
    fi
    exit 0
fi

# ----- Runtime detection -----
if command -v podman >/dev/null 2>&1; then
    CONTAINER_CMD="podman"
elif command -v docker >/dev/null 2>&1; then
    CONTAINER_CMD="docker"
else
    echo -e "\033[0;31m❌ Не найден ни podman, ни docker\033[0m"
    exit 1
fi

# ----- Проверка podman remote (macOS всегда remote, Linux — по наличию RemoteSocket) -----
PODMAN_REMOTE=0
if [ "$CONTAINER_CMD" = "podman" ]; then
    if [ "$(uname)" = "Darwin" ]; then
        PODMAN_REMOTE=1
    elif podman info --format '{{.Host.RemoteSocket.Path}}' 2>/dev/null | grep -q .; then
        PODMAN_REMOTE=1
    fi
fi

if [ "$CONTAINER_CMD" = "podman" ] && [ "$PODMAN_REMOTE" = "1" ]; then
    USER_OPTS=""
elif [ "$CONTAINER_CMD" = "podman" ]; then
    USER_OPTS="--userns=keep-id --group-add keep-groups"
else
    USER_OPTS="--user $(id -u):$(id -g) --group-add keep-groups"
fi

# ----- Обработка --stop -----
if [ "${1:-}" = "--stop" ]; then
    # Если указана папка — ищем контейнер по хэшу, иначе — все qcc-*
    STOPPED=0
    for name in $($CONTAINER_CMD ps --format '{{.Names}}' 2>/dev/null | grep '^qcc-'); do
        $CONTAINER_CMD stop "$name" >/dev/null 2>&1 && STOPPED=1
    done
    if [ $STOPPED -eq 1 ]; then
        echo -e "${GREEN}✅ Контейнеры qcc остановлены${NC}"
    else
        echo "⚠️  Нет запущенных контейнеров qcc"
    fi
    exit 0
fi

# ----- Создание глобальных директорий -----
mkdir -p "$GLOBAL_CONFIG_DIR"/{npm,config,skills,oauth}
mkdir -p "$GLOBAL_CONFIG_DIR/projects"
mkdir -p "$PROJECT_CONFIG_DIR"

# Миграция OAuth из старой проектной директории в глобальную
# TODO: убрать после достаточного времени (разовая миграция для старых пользователей)
if [ -d "$PROJECT_QWEN_DIR" ] && [ -d "$PROJECT_QWEN_DIR/oauth_creds" ]; then
    if [ ! -d "$GLOBAL_CONFIG_DIR/oauth/oauth_creds" ]; then
        cp -r "$PROJECT_QWEN_DIR/oauth_creds" "$GLOBAL_CONFIG_DIR/oauth/" 2>/dev/null || true
    fi
fi
if [ -f "$PROJECT_QWEN_DIR/oauth_creds.json" ] 2>/dev/null; then
    if [ ! -f "$GLOBAL_CONFIG_DIR/oauth/oauth_creds.json" ]; then
        cp "$PROJECT_QWEN_DIR/oauth_creds.json" "$GLOBAL_CONFIG_DIR/oauth/" 2>/dev/null || true
    fi
fi

# ----- Инициализация шаблонов (один раз) -----
# 1. Глобальные скиллы из шаблонов
if [ -d "$SCRIPT_DIR/../config-templates/skills" ]; then
    for f in "$SCRIPT_DIR/../config-templates/skills"/*.md; do
        [ -f "$f" ] || continue
        name=$(basename "$f")
        [ ! -f "$GLOBAL_CONFIG_DIR/skills/$name" ] && cp "$f" "$GLOBAL_CONFIG_DIR/skills/$name"
    done
fi
# 2. Глобальные агент-конфиги из шаблонов
if [ -d "$SCRIPT_DIR/../config-templates/agent" ]; then
    for f in "$SCRIPT_DIR/../config-templates/agent"/*; do
        [ -f "$f" ] || continue
        name=$(basename "$f")
        [ ! -f "$GLOBAL_CONFIG_DIR/$name" ] && cp "$f" "$GLOBAL_CONFIG_DIR/$name"
    done
fi
# 3. Проектные скиллы: глобальные → проектные
if [ -d "$GLOBAL_CONFIG_DIR/skills" ]; then
    mkdir -p "$PROJECT_CONFIG_DIR/skills"
    for f in "$GLOBAL_CONFIG_DIR/skills"/*.md; do
        [ -f "$f" ] || continue
        name=$(basename "$f")
        [ ! -f "$PROJECT_CONFIG_DIR/skills/$name" ] && cp "$f" "$PROJECT_CONFIG_DIR/skills/$name"
    done
fi
# 4. Проектные агент-конфиги: глобальные → проектные
if [ -d "$GLOBAL_CONFIG_DIR" ]; then
    for f in AGENTS.md; do
        [ -f "$GLOBAL_CONFIG_DIR/$f" ] || continue
        [ ! -f "$PROJECT_CONFIG_DIR/$f" ] && cp "$GLOBAL_CONFIG_DIR/$f" "$PROJECT_CONFIG_DIR/$f"
    done
fi
# 5. Шаблоны .qwen
if [ -d "$SCRIPT_DIR/../config-templates/qwen" ]; then
    mkdir -p "$PROJECT_QWEN_DIR"
    for f in "$SCRIPT_DIR/../config-templates/qwen"/*; do
        [ -f "$f" ] || continue
        name=$(basename "$f")
        [[ "$name" == ".gitignore" ]] && continue
        [ ! -f "$PROJECT_QWEN_DIR/$name" ] && cp "$f" "$PROJECT_QWEN_DIR/$name"
    done
fi

# ----- Обработка .qwenignore (простое перекрытие) -----
OVERLAY_VOLUMES=()
if [ -f "$PROJECT_DIR/.qwenignore" ]; then
    echo -e "${BLUE}📋 Найден .qwenignore — перекрываю указанные файлы${NC}"
    while IFS= read -r line; do
        pattern=$(echo "$line" | sed 's/#.*//' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        [ -z "$pattern" ] && continue
        # Ищем файлы по паттерну (глубина 2)
        while IFS= read -r -d '' file; do
            rel="${file#$PROJECT_DIR/}"
            [ -n "$rel" ] && OVERLAY_VOLUMES+=(-v "/workspace/$rel")
        done < <(find "$PROJECT_DIR" -maxdepth 2 -path "$PROJECT_DIR/$pattern" -type f -print0 2>/dev/null || true)
    done < "$PROJECT_DIR/.qwenignore"
fi

# ----- Модель -----
MODEL_ARGS=()
if [ "$QWEN_MODEL_EXPLICIT" = "1" ] && [ -n "$QWEN_MODEL" ]; then
    MODEL_ARGS=(--model "$QWEN_MODEL")
    echo -e "${BLUE}🤖 Модель (из Makefile): $QWEN_MODEL${NC}"
elif [ -f "$GLOBAL_CONFIG_DIR/model" ]; then
    MODEL_ARGS=(--model "$(cat "$GLOBAL_CONFIG_DIR/model")")
    echo -e "${BLUE}🤖 Модель (из конфига): $(cat "$GLOBAL_CONFIG_DIR/model")${NC}"
else
    echo -e "${YELLOW}⚠️  Модель не задана — используется по умолчанию от провайдера${NC}"
fi

# ----- Git config -----
GIT_ENVS=()
if git config --global user.name >/dev/null 2>&1; then
    GIT_ENVS+=(-e "GIT_CONFIG_NAME=$(git config --global user.name)")
fi
if git config --global user.email >/dev/null 2>&1; then
    GIT_ENVS+=(-e "GIT_CONFIG_EMAIL=$(git config --global user.email)")
fi

# ----- Монтирования -----
VOLUMES=(
    -v "$PROJECT_DIR":/workspace
    -v "$GLOBAL_CONFIG_DIR/npm":/root/.npm
    -v "$GLOBAL_CONFIG_DIR/config":/root/.config
)

# Проектные скиллы и .qwen (rw — можно редактировать)
if [ -d "$PROJECT_CONFIG_DIR/skills" ]; then
    VOLUMES+=(-v "$PROJECT_CONFIG_DIR/skills":/workspace/.qwen/skills)
fi
VOLUMES+=(-v "$PROJECT_QWEN_DIR":/workspace/.qwen)

# /root/.qwen — qwen-code хранит здесь авторизацию (OAuth) и сессии
# Глобальная папка — авторизация общая для всех проектов
VOLUMES+=(-v "$GLOBAL_CONFIG_DIR/oauth":/root/.qwen)

# Проектный AGENTS.md (rw — можно редактировать)
if [ -f "$PROJECT_CONFIG_DIR/AGENTS.md" ]; then
    VOLUMES+=(-v "$PROJECT_CONFIG_DIR/AGENTS.md":/workspace/AGENTS.md)
fi

# Entrypoint скрипт (используем реальный путь)
ENTRYPOINT_SOURCE="$SCRIPT_DIR/../container/entrypoint.sh"
if [ -f "$ENTRYPOINT_SOURCE" ]; then
    VOLUMES+=(-v "$ENTRYPOINT_SOURCE":/usr/local/bin/git-entrypoint.sh:ro)
else
    echo -e "${YELLOW}⚠️  Предупреждение: $ENTRYPOINT_SOURCE не найден, entrypoint не будет смонтирован${NC}"
fi

# tmpfs поверх /workspace/.npm и /workspace/.config — защита от загрязнения проекта.
# Если процесс внутри контейнера пишет по этим путям, данные уходят в RAM, а не в проект.
# Реальный кэш/конфиги доступны через /root/.npm и /root/.config (bind-mount выше).
TMPFS=(--tmpfs /workspace/.npm:mode=755 --tmpfs /workspace/.config:mode=755)

# ----- Проверка: если контейнер для этого проекта уже запущен -----
if $CONTAINER_CMD ps --format '{{.Names}}' 2>/dev/null | grep -q "^${CONTAINER_NAME}$"; then
    echo -e "${YELLOW}🔌 Контейнер уже запущен из этого проекта${NC}"
    echo "  Проект: $PROJECT_DIR"

    if [ "${1:-}" = "--new" ]; then
        echo -e "${BLUE}🆕 Флаг --new — перезапускаю контейнер...${NC}"
        $CONTAINER_CMD stop "$CONTAINER_NAME" >/dev/null 2>&1
    elif [ "${1:-}" = "--attach" ]; then
        echo -e "${BLUE}🔌 Флаг --attach — подключаюсь к сессии...${NC}"
        exec $CONTAINER_CMD attach --sig-proxy=false "$CONTAINER_NAME"
    else
        echo ""
        echo "  [1] Подключиться к существующей сессии"
        echo "  [2] Перезапустить контейнер"
        echo ""
        printf "Выбор [1]: "
        read -r CHOICE
        if [ "$CHOICE" = "2" ]; then
            echo -e "${BLUE}🆕 Перезапускаю контейнер...${NC}"
            $CONTAINER_CMD stop "$CONTAINER_NAME" >/dev/null 2>&1
        else
            echo -e "${BLUE}🔌 Подключаюсь к сессии...${NC}"
            exec $CONTAINER_CMD attach --sig-proxy=false "$CONTAINER_NAME"
        fi
    fi
fi

# ----- Запуск нового контейнера -----
echo -e "${GREEN}🔍 Qwen Code Launcher (прямой запуск)${NC}"
echo "Проект: $PROJECT_DIR"

# Ищем свободный порт на хосте
RESOLVED_HOST_PORT=$(find_free_port "$HOST_PORT")
if [ "$RESOLVED_HOST_PORT" != "$HOST_PORT" ]; then
    echo -e "${YELLOW}📌 Порт $HOST_PORT занят — использую $RESOLVED_HOST_PORT${NC}"
fi

if [ $DEBUG_MODE -eq 1 ]; then
    echo -e "${YELLOW}🔍 DEBUG: команда запуска:${NC}"
    echo "$CONTAINER_CMD run --rm -it \\"
    echo "    $USER_OPTS \\"
    echo "    --security-opt label=disable --security-opt no-new-privileges:true \\"
    echo "    --label qcc.project_hash=$PROJECT_HASH \\"
    echo "    ${VOLUMES[@]+"${VOLUMES[@]}"} \\"
    echo "    ${OVERLAY_VOLUMES[@]+"${OVERLAY_VOLUMES[@]}"} \\"
    echo "    ${TMPFS[@]+"${TMPFS[@]}"} \\"
    echo "    ${GIT_ENVS[@]+"${GIT_ENVS[@]}"} \\"
    echo "    -e QWEN_ALLOW_RUN_IN_HOME=1 \\"
    echo "    -w /workspace \\"
    echo "    --entrypoint /usr/local/bin/git-entrypoint.sh \\"
    echo "    -p ${RESOLVED_HOST_PORT}:${CONTAINER_PORT} \\"
    echo "    $QWEN_IMAGE \\"
    echo "    qwen ${MODEL_ARGS[@]+"${MODEL_ARGS[@]}"}"
    exit 0
fi

exec $CONTAINER_CMD run --rm -it \
    --name "$CONTAINER_NAME" \
    $USER_OPTS \
    --security-opt label=disable --security-opt no-new-privileges:true \
    --label "qcc.project_hash=$PROJECT_HASH" \
    ${VOLUMES[@]+"${VOLUMES[@]}"} \
    ${OVERLAY_VOLUMES[@]+"${OVERLAY_VOLUMES[@]}"} \
    ${TMPFS[@]+"${TMPFS[@]}"} \
    ${GIT_ENVS[@]+"${GIT_ENVS[@]}"} \
    -e QWEN_ALLOW_RUN_IN_HOME=1 \
    -w /workspace \
    --entrypoint /usr/local/bin/git-entrypoint.sh \
    -p "${RESOLVED_HOST_PORT}:${CONTAINER_PORT}" \
    "$QWEN_IMAGE" \
    qwen ${MODEL_ARGS[@]+"${MODEL_ARGS[@]}"}
