# .env.example
# Скопируйте в .env и отредактируйте при необходимости

# Образ Docker
QWEN_IMAGE=ghcr.io/qwenlm/qwen-code:0.14.1

# Имя папки с глобальными конфигами
QWEN_CONFIG_NAME=qwen-code-container

# Модель для AI
QWEN_MODEL=qwen-coder

# Проброс порта (если потребуется веб-сервер)
HOST_PORT=5173
CONTAINER_PORT=5173
