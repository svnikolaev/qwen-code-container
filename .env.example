# .env.example
# Скопируйте в .env и отредактируйте при необходимости

# Режим песочницы (по умолчанию true, использует Docker для изоляции)
QWEN_SANDBOX=true

# Альтернативный образ песочницы (опционально)
# QWEN_SANDBOX_IMAGE=ghcr.io/qwenlm/qwen-code:latest

# API ключи (если не хотите использовать OAuth)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-...
# GOOGLE_API_KEY=...

# Проброс порта (если потребуется веб-сервер, например 5173)
HOST_PORT=5173
CONTAINER_PORT=5173

# Автоматическое перекрытие всех секретов без вопросов (0 или 1)
# QWEN_AUTO_BLOCK_SECRETS=0

# Принудительно обновить выбор перекрытия при запуске (0 или 1)
# QWEN_REFRESH_BLOCK=0

# Дополнительные паттерны для поиска секретов (bash-массив)
# QWEN_SECRET_PATTERNS=(".env" "*.key")